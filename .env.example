# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/sport_federation

# NextAuth
AUTH_SECRET=replace-with-a-random-32-byte-base64-string
AUTH_URL=http://localhost:3000

# Email (for notifications, e.g. passport expiry)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Sport Federation Portal <no-reply@example.com>"

# PDF generation (Puppeteer). Leave unset for local dev — it uses its own
# bundled Chromium. On a Linux server, set this to the apt-installed
# Google Chrome binary, e.g. /usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=
